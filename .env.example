# =========================================================================
# BUS TZ PAWA — Environment template
# Copy to .env (or to your n8n / Supabase / VAPI dashboards). Never commit
# the real .env. See ENVIRONMENT.md for what each one does.
# =========================================================================

# ---------- Anthropic (Claude is the agent's brain) ----------
ANTHROPIC_API_KEY=

# ---------- Supabase (website Postgres) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Booking Postgres (n8n) ----------
# These go into the n8n "Postgres BUS TZ PAWA" credential, not the .env file —
# kept here as a checklist of fields you'll need to enter in the n8n UI.
PG_BOOKING_HOST=
PG_BOOKING_DB=bustanzania
PG_BOOKING_USER=
PG_BOOKING_PASSWORD=
PG_BOOKING_PORT=5432
PG_BOOKING_SSL=true

# ---------- Website Postgres (n8n credential `Postgres Pawa Website`) ----------
# Point this at the same Supabase project the website uses.
PG_WEBSITE_HOST=
PG_WEBSITE_DB=postgres
PG_WEBSITE_USER=
PG_WEBSITE_PASSWORD=
PG_WEBSITE_PORT=5432
PG_WEBSITE_SSL=true

# ---------- Africa's Talking (SMS + WhatsApp) ----------
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=
AT_WHATSAPP_NUMBER=

# ---------- VAPI ----------
VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# ---------- Payment gateway ----------
PRIMARY_PROVIDER=selcom
PAYMENT_GATEWAY_URL=
PAYMENT_GATEWAY_TOKEN=
PAYMENT_GATEWAY_SECRET=
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=
CLICKPESA_CLIENT_ID=
CLICKPESA_API_KEY=
CLICKPESA_WEBHOOK_SECRET=
AZAMPAY_TOKEN=
AZAMPAY_CLIENT_ID=
AZAMPAY_CLIENT_SECRET=
AZAMPAY_APP_NAME=
FLW_SECRET_KEY=
FLW_HASH=

# ---------- Manager / escalation ----------
MANAGER_PHONE=
MANAGER_EMAILS=
MANAGER_FROM_EMAIL=
MANAGER_NOTIFY_URL=
MANAGER_NOTIFY_TOKEN=

# ---------- n8n base ----------
N8N_WEBHOOK_BASE=

# ---------- Maps / Weather (optional) ----------
MAPBOX_TOKEN=

# ---------- Go map gateway (services/go) ----------
# The gateway geocodes through OpenStreetMap. The public Nominatim server
# rate-limits (429) shared/cloud IPs, so in production set a LocationIQ key
# (hosted Nominatim, same API) to get your own quota. Get a free key at
# https://locationiq.com (5,000 req/day). Set this on the gateway host (Render).
# Leave empty to use public Nominatim (fine for local dev / self-hosted).
LOCATIONIQ_KEY=
# Optional: regional endpoint, default https://us1.locationiq.com/v1 (or eu1).
LOCATIONIQ_BASE=
