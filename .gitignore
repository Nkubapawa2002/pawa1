# Dependencies
node_modules/
__pycache__/
*.pyc

# Local env / secrets
.env
.env.local
.env.*.local

# Local runtime config — Mapbox token and any other client-side keys you
# don't want in the public repo. Load it after config.js in HTML pages:
#   <script src="js/config.js"></script>
#   <script src="js/config.local.js"></script>
js/config.local.js

# Image backups (kept locally, not needed in the repo — ~20MB)
data/_originals/

# Editor / IDE
.vscode/
.idea/
*.swp

# Claude Code local settings — contains permission allowlist with
# captured commands (including secrets from prior sessions). NEVER commit.
.claude/settings.local.json
.claude/projects/

# OS files
.DS_Store
Thumbs.db

# Build / temp artifacts from scratch curls and tests
headers.txt
response.json
*.log

# Test screenshots — large binary noise, regenerated on each run
test-screenshots/
tests/_nm.png

# Scratch Puppeteer smoke script (needs a live server; not part of the suite)
_nmtest.mjs

# Migration files staged for one-off application (kept out of history)
supabase/_migration_section*.sql

# Supabase CLI local scratch (project link, cached CLI version) — not source
supabase/.temp/

# Capacitor native app build artifacts (www/ is regenerated by scripts/build_app.mjs)
www/
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
backup_legacy_busridepostal_2026-06-20.json
backup_demo_agents_2026-06-20.json
backup_meet_locations_2026-06-20.json
